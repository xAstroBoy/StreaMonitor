{
    "name": "streamonitor",
    "version-string": "2.0.0",
    "builtin-baseline": "e0edebd1dc2d03cf7d02349df91de74ef4d0c00e",
    "description": "Stream monitoring and recording application with native FFmpeg, ImGui GUI",
    "dependencies": [
        {
            "name": "curl",
            "features": [
                "ssl",
                "sspi"
            ]
        },
        "openssl",
        "nlohmann-json",
        {
            "name": "spdlog",
            "features": [
                "wchar"
            ]
        },
        "fmt",
        {
            "name": "ffmpeg",
            "default-features": false,
            "features": [
                "avformat",
                "avcodec",
                "avfilter",
                "swscale",
                "swresample",
                "nvcodec",
                "x264",
                "x265",
                "gpl"
            ]
        },
        "nghttp2"
    ]
}